// ===========================================================================
// English Streak - Prisma schema
// ===========================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// User
// A Discord user that has interacted with the bot at least once.
// Only the strictly necessary, non-sensitive data is stored.
// ---------------------------------------------------------------------------
model User {
  id        String @id @default(uuid())
  discordId String @unique
  username  String

  points                 Int @default(0)
  totalCorrectAnswers    Int @default(0)
  totalQuestionsAnswered Int @default(0)

  currentStreak Int @default(0)
  bestStreak    Int @default(0)

  // The (UTC, date-only) day the user last fully completed the daily challenge.
  lastDailyCompleted DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  answers     UserAnswer[]
  guildScores GuildScore[]

  @@index([points])
  @@index([currentStreak])
  @@map("users")
}

// ---------------------------------------------------------------------------
// GuildScore
// Per-server score for a user. Points are attributed to the server the user
// started the daily challenge from (session.guildId). This powers the
// per-server leaderboard, while the global ranking still reads from User.
// ---------------------------------------------------------------------------
model GuildScore {
  id       String @id @default(uuid())
  guildId  String
  userId   String
  username String // denormalized for display without a join

  points                 Int @default(0)
  totalCorrectAnswers    Int @default(0)
  totalQuestionsAnswered Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([guildId, userId])
  @@index([guildId, points])
  @@map("guild_scores")
}

// ---------------------------------------------------------------------------
// DailyQuestion
// The set of questions selected for a given day. Each day has N rows
// (one per selected question). "questionId" references the question id inside
// the static questions JSON file (data/questions.json).
// ---------------------------------------------------------------------------
model DailyQuestion {
  id         String   @id @default(uuid())
  questionId Int
  date       DateTime // date-only (UTC midnight) representing the challenge day
  createdAt  DateTime @default(now())

  @@unique([date, questionId])
  @@index([date])
  @@map("daily_questions")
}

// ---------------------------------------------------------------------------
// UserAnswer
// One row per answered question. Used for stats and to prevent answering the
// same daily question twice.
// ---------------------------------------------------------------------------
model UserAnswer {
  id         String   @id @default(uuid())
  userId     String
  questionId Int
  isCorrect  Boolean
  answeredAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([questionId])
  @@index([answeredAt])
  @@map("user_answers")
}

// ---------------------------------------------------------------------------
// EventLog
// Audit + idempotency ledger for the private events API. Every event the API
// accepts is recorded here BEFORE the worker mutates scores, so each event is
// processed at most once (unique idempotencyKey) and there is a durable trail
// of what changed and why. Written exclusively by the closed-source API worker;
// the bot never writes here (it only owns the schema so `db push` creates it).
// IDs here are the Discord ids carried in the event (not internal User.id).
// ---------------------------------------------------------------------------
model EventLog {
  id             String  @id @default(uuid())
  idempotencyKey String  @unique
  eventType      String // 'answer' | 'daily_completed'
  guildId        String
  userId         String // Discord user id as received in the event
  questionId     Int? // null for daily_completed events
  isCorrect      Boolean?
  pointsAwarded  Int     @default(0)
  processed      Boolean @default(false)
  error          String?
  // JSON of the original queue job, so a reconciler can safely re-enqueue an
  // event that got stuck unprocessed (transactional-outbox recovery).
  payload        String?

  createdAt   DateTime  @default(now())
  processedAt DateTime?

  @@index([guildId, userId])
  @@index([eventType])
  @@index([processed])
  @@map("event_logs")
}
