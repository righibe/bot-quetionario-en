# ==========================================================================
# English Streak - Variáveis de ambiente
# --------------------------------------------------------------------------
# Copie este arquivo para ".env" e preencha os valores reais:
#   cp .env.example .env
# Nunca faça commit do seu .env real (já está no .gitignore).
# ==========================================================================

# === Discord ===
# Token do bot (Discord Developer Portal > Bot > Reset Token)
# O Client ID é descoberto automaticamente a partir do token.
DISCORD_TOKEN=cole-seu-token-aqui

# IDs dos canais (Modo Desenvolvedor > clique direito no canal > Copiar ID)
CHANNEL_DAILY_QUESTIONS=000000000000000000
CHANNEL_RANKING=000000000000000000

# === Banco (Postgres) ===
# A connection string é montada automaticamente a partir das variáveis abaixo.
POSTGRES_USER=english_streak
POSTGRES_PASSWORD=troque-esta-senha
POSTGRES_DB=english_streak
# Host/porta (opcionais). No docker compose o host é definido como "postgres".
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Alternativa: defina uma URL completa (tem prioridade sobre as POSTGRES_* acima).
# Necessária se você for rodar os comandos do Prisma CLI fora do Docker.
# DATABASE_URL="postgresql://english_streak:troque-esta-senha@localhost:5432/english_streak?schema=public"

# === Aplicação ===
# Fuso horário do cron diário (nome IANA). Ex.: America/Sao_Paulo
TZ=America/Sao_Paulo

# Expressão cron do reset diário (padrão: meia-noite todos os dias).
DAILY_CRON=0 0 * * *

# Nível de log: debug | info | warn | error
LOG_LEVEL=info
